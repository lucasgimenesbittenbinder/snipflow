{
  "name": "snipflow",
  "version": "1.0.1",
  "description": "A simple and fast code snippet manager CLI.",
  "type": "module",
  "bin": {
    "snip": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "cli",
    "snippets",
    "clipboard",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasgimenesbittenbinder/snipflow.git"
  },
  "bugs": {
    "url": "https://github.com/lucasgimenesbittenbinder/snipflow/issues"
  },
  "homepage": "https://github.com/lucasgimenesbittenbinder/snipflow#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/core": "^10.3.2",
    "@inquirer/prompts": "^7.10.1",
    "chalk": "^5.6.2",
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0",
    "fuse.js": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
